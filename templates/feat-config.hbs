<div class="pf2e-sf2e-extra-feat-slots-feat-config">
    <p>{{localize "pf2e-sf2e-extra-feat-slots.SETTINGS.config.instructions"}}</p>
    <table>
        <tr>
            <td><label for="presets">{{localize "pf2e-sf2e-extra-feat-slots.SETTINGS.config.preset.label"}}</label></td>
            <td>
                <select name="sectionPresets" id="sectionPresets">
                    <option value="ancestryParagon" data-section-id="ancestryParagon">{{localize "pf2e-sf2e-extra-feat-slots.SETTINGS.ancestryParagon.name"}}</option>
                    <option value="skillParagon" data-section-id="skillParagon">{{localize "pf2e-sf2e-extra-feat-slots.SETTINGS.skillParagon.name"}}</option>
                    <option value="magaambyaBenefits" data-section-id="magaambyaBenefits">{{localize "pf2e-sf2e-extra-feat-slots.SETTINGS.magaambyaBenefits.name"}}</option>
                </select>
            </td>
            <td><button type="button" data-action="addPreset"><i class="fa-solid fa-plus"></i>{{localize "pf2e-sf2e-extra-feat-slots.SETTINGS.config.preset.button"}}</button></td>
        </tr>
    </table>
    <table>
        <tr>
            <th>{{localize "pf2e-sf2e-extra-feat-slots.SETTINGS.config.header.label"}}</th>
            <th>{{localize "pf2e-sf2e-extra-feat-slots.SETTINGS.config.header.type"}}</th>
            <th>{{localize "pf2e-sf2e-extra-feat-slots.SETTINGS.config.header.levels"}}</th>
            <th></th>
        </tr>
        {{#each featSections as |section i|}}
        <tr>
            <td>{{section.label}}</td>
            <td>
                {{#each section.supported as |type t|}} <div class="tag">{{pf2eSf2eExtraFeatSlotsFormatTagLabel type}}</div> {{else}} <div class="tag">{{localize "pf2e-sf2e-extra-feat-slots.SETTINGS.config.any"}}</div> {{/each}}
            </td>
            <td>{{#each section.slots as |level l|}} <div class="tag">{{level}}</div> {{else}} <div class="tag">{{localize "pf2e-sf2e-extra-feat-slots.SETTINGS.config.none"}}</div> {{/each}}</td>
            <td>
                <button type="button" data-action="removeSection" data-section-id="{{section.id}}"><i class="fas fa-trash"></i></button>
                <button type="button" data-action="editSection" data-section-id="{{section.id}}"><i class="fas fa-pencil"></i></button>
            </td>
        </tr>
        {{/each}}
    </table>
    
    <footer class="form-footer">
        <button type="button" data-action="saveSections"><i class="fa-solid fa-floppy-disk"></i>{{localize "pf2e-sf2e-extra-feat-slots.SETTINGS.config.save"}}</button>
        <button type="button" data-action="addSection"><i class="fa-regular fa-plus"></i>{{localize "pf2e-sf2e-extra-feat-slots.SETTINGS.config.add"}}</button>
    </footer>
    
</div>